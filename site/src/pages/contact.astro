---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { businessInfo } from '../data/business-info';
import { buildBreadcrumbSchema } from '../lib/schema';
import JsonLd from '../components/JsonLd.astro';

const phone = '07936 085632';
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
const email = 'warboysgutterclearing@btinternet.com';

const siteUrl = businessInfo.url;
const breadcrumbSchema = buildBreadcrumbSchema(siteUrl, [
  { name: 'Home', url: siteUrl },
  { name: 'Contact Us', url: `${siteUrl}/contact` },
]);
---

<BaseLayout title="Contact Us" description="Get in touch with Warboys Gutter Clearing for a free quote. Call, email, or fill in our contact form.">
  <Fragment slot="head">
    <JsonLd schema={breadcrumbSchema} />
  </Fragment>
  <section class="contact-page">
    <div class="contact-page__container">
      <h1 class="contact-page__heading">Contact Us</h1>
      <p class="contact-page__intro">
        Ready to get your gutters cleared? Fill in the form below or get in touch directly — we'd love to hear from you.
      </p>

      <div class="contact-page__grid">
        <div class="contact-page__form-col">
          <ContactForm />
        </div>

        <aside class="contact-page__details-col">
          <h2 class="contact-page__details-heading">Get in Touch</h2>

          <div class="contact-page__detail">
            <svg class="contact-page__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <div>
              <span class="contact-page__detail-label">Phone</span>
              <a href={phoneHref} class="contact-page__detail-value contact-page__link">{phone}</a>
            </div>
          </div>

          <div class="contact-page__detail">
            <svg class="contact-page__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <div>
              <span class="contact-page__detail-label">Email</span>
              <a href={`mailto:${email}`} class="contact-page__detail-value contact-page__link">{email}</a>
            </div>
          </div>

          <div class="contact-page__detail">
            <svg class="contact-page__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <span class="contact-page__detail-label">Service Area</span>
              <span class="contact-page__detail-value">Warboys &amp; Cambridgeshire</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: var(--space-xl) var(--space-md);
    background-color: var(--color-bg-grey);
  }

  .contact-page__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-page__heading {
    font-family: var(--font-heading);
    color: var(--color-text-dark);
    text-align: center;
    margin-bottom: var(--space-sm);
  }

  .contact-page__intro {
    text-align: center;
    color: #555;
    max-width: 600px;
    margin: 0 auto var(--space-xl);
    font-size: 1.1rem;
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .contact-page__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .contact-page__form-col {
    background-color: var(--color-bg-white);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .contact-page__details-col {
    background-color: var(--color-secondary);
    color: var(--color-text-light);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .contact-page__details-heading {
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
    font-size: 1.5rem;
  }

  .contact-page__detail {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .contact-page__icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 2px;
  }

  .contact-page__detail-label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .contact-page__detail-value {
    display: block;
    font-size: 1.05rem;
    color: var(--color-text-light);
  }

  .contact-page__link {
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .contact-page__link:hover {
    color: var(--color-primary);
  }
</style>
