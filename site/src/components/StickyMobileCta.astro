---
// StickyMobileCta — fixed bottom bar with Call Now and Get Quote buttons (mobile only)
const phone = '07936 085632';
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<div class="sticky-mobile-cta" role="navigation" aria-label="Quick contact actions">
  <a href={phoneHref} class="cta-button sticky-mobile-cta__btn">
    <svg class="sticky-mobile-cta__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.86 19.86 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.86 19.86 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.13.81.36 1.6.68 2.34a2 2 0 01-.45 2.11L8.09 9.41a16 16 0 006.5 6.5l1.24-1.24a2 2 0 012.11-.45c.74.32 1.53.55 2.34.68a2 2 0 011.72 2.03z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Call Now
  </a>
  <a href="/contact" class="cta-button sticky-mobile-cta__btn">
    <svg class="sticky-mobile-cta__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Get Quote
  </a>
</div>

<style>
  .sticky-mobile-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1100;
    display: flex;
    background-color: var(--color-primary);
    padding: var(--space-sm);
    gap: var(--space-sm);
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.2);
  }

  .sticky-mobile-cta__btn {
    flex: 1;
    background-color: var(--color-secondary);
    color: var(--color-primary);
    font-size: 0.9rem;
    gap: var(--space-xs);
  }

  .sticky-mobile-cta__btn:hover {
    background-color: #222222;
  }

  .sticky-mobile-cta__icon {
    flex-shrink: 0;
  }

  /* Hidden on viewports >= 768px */
  @media (min-width: 768px) {
    .sticky-mobile-cta {
      display: none;
    }
  }
</style>
