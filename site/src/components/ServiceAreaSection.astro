---
// ServiceAreaSection — Lists covered towns/villages in Cambridgeshire with Warboys as primary base
---

<section class="service-area" id="service-area">
  <div class="service-area__inner">
    <h2 class="service-area__heading">Our Service Area</h2>
    <p class="service-area__intro">
      Based in <strong>Warboys</strong>, we proudly serve homes and businesses across Cambridgeshire.
      If your town isn't listed below, get in touch — we may still be able to help.
    </p>

    <ul class="service-area__list">
      <li class="service-area__item service-area__item--primary">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="2"/>
          <circle cx="9" cy="9" r="3" fill="currentColor"/>
        </svg>
        Warboys
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Ramsey
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        St Ives
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Huntingdon
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Somersham
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Chatteris
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        March
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Ely
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        St Neots
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Godmanchester
      </li>
      <li class="service-area__item">
        <svg class="service-area__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L9 9L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Sawtry
      </li>
    </ul>
  </div>
</section>

<style>
  .service-area {
    background-color: var(--color-bg-grey);
    padding: var(--space-xl) var(--space-md);
  }

  .service-area__inner {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .service-area__heading {
    color: var(--color-text-dark);
    margin-bottom: var(--space-lg);
  }

  .service-area__intro {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-dark);
    margin-bottom: var(--space-lg);
  }

  .service-area__intro strong {
    color: var(--color-secondary);
  }

  .service-area__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm) var(--space-lg);
    text-align: left;
    max-width: 720px;
    margin: 0 auto;
  }

  .service-area__item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1rem;
    color: var(--color-text-dark);
    padding: var(--space-xs) 0;
  }

  .service-area__item--primary {
    font-weight: 700;
    color: var(--color-secondary);
  }

  .service-area__item--primary .service-area__icon {
    color: var(--color-primary);
  }

  .service-area__icon {
    flex-shrink: 0;
    color: var(--color-secondary);
  }

  @media (max-width: 767px) {
    .service-area__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm) var(--space-md);
    }
  }

  @media (max-width: 479px) {
    .service-area__list {
      grid-template-columns: 1fr;
    }
  }
</style>
