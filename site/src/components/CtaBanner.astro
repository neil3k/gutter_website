---
// CtaBanner — full-width Primary_Colour CTA block with hazard stripe accents
const phone = '07936 085632';
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<section class="cta-banner" id="cta-banner">
  <div class="cta-banner__stripe cta-banner__stripe--top" aria-hidden="true"></div>

  <div class="cta-banner__inner">
    <h2 class="cta-banner__heading">Ready to Get Your Gutters Cleared?</h2>
    <p class="cta-banner__text">Whether your gutters are overflowing, blocked with moss and leaves, or you just want to stay on top of maintenance, we're here to help.</p>
    <p class="cta-banner__text">Get in touch today for a free, no-obligation quote.</p>

    <div class="cta-banner__ctas">
      <a href="/contact" class="cta-button cta-button--secondary">Get a Free Quote</a>
      <a href={phoneHref} class="cta-button cta-button--phone">
        <svg class="cta-banner__phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.86 19.86 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.86 19.86 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.13.81.36 1.6.68 2.34a2 2 0 01-.45 2.11L8.09 9.41a16 16 0 006.5 6.5l1.24-1.24a2 2 0 012.11-.45c.74.32 1.53.55 2.34.68a2 2 0 011.72 2.03z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Call Now
      </a>
    </div>
  </div>

  <div class="cta-banner__stripe cta-banner__stripe--bottom" aria-hidden="true"></div>
</section>

<style>
  .cta-banner {
    position: relative;
    background-color: var(--color-primary);
    width: 100%;
  }

  /* Hazard stripe accent — repeating diagonal yellow/black pattern */
  .cta-banner__stripe {
    height: 12px;
    background: repeating-linear-gradient(
      -45deg,
      var(--color-primary),
      var(--color-primary) 10px,
      var(--color-secondary) 10px,
      var(--color-secondary) 20px
    );
  }

  .cta-banner__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    text-align: center;
  }

  .cta-banner__heading {
    color: var(--color-secondary);
    margin-bottom: var(--space-md);
  }

  .cta-banner__text {
    color: var(--color-secondary);
    font-size: 1.15rem;
    margin-bottom: var(--space-lg);
  }

  .cta-banner__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  /* Override secondary button for dark-on-yellow context */
  .cta-banner .cta-button--secondary {
    background-color: var(--color-secondary);
    color: var(--color-text-light);
    border: 2px solid var(--color-secondary);
  }

  .cta-banner .cta-button--secondary:hover {
    background-color: #222222;
    border-color: #222222;
  }

  .cta-button--phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--cta-min-size);
    min-height: var(--cta-min-size);
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-white);
    color: var(--color-secondary);
    border: 2px solid var(--color-secondary);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.1s ease;
  }

  .cta-button--phone:hover {
    background-color: var(--color-bg-grey);
  }

  .cta-button--phone:active {
    transform: scale(0.97);
  }

  .cta-banner__phone-icon {
    width: 20px;
    height: 20px;
    margin-right: var(--space-xs);
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .cta-banner__inner {
      padding: var(--space-lg) var(--space-md);
    }

    .cta-banner__ctas {
      flex-direction: column;
      align-items: center;
    }

    .cta-banner__ctas .cta-button--secondary,
    .cta-banner__ctas .cta-button--phone {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
